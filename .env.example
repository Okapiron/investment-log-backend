# Local default (if omitted): sqlite:///./app.db
# DATABASE_URL=sqlite:///./app.db

# Render / Postgres example
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
# APP_VERSION=2026.03.08

# Auth (Supabase)
# AUTH_ENABLED=true
# PRIVATE_MODE_ENABLED=true
# PRIVATE_MODE_SECRET=change-me
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# INVITE_CODE_REQUIRED=true
# OPS_ALERT_TARGET=slack:#tradetrace-alerts
# DB_BACKUP_STRATEGY=render-managed-daily

# AI analysis (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1/responses
# OPENAI_TIMEOUT_MS=12000
# ANALYSIS_CACHE_TTL_SECONDS=300
# ANALYSIS_MOCK_ENABLED=true

# Public v1 release scope
# PUBLIC_V1_MODE=true
# IMPORT_SBI_ENABLED=false
# PRICE_API_ENABLED=false
# ALLOW_UNOFFICIAL_PRICE_SOURCE=false

# Price source
# PRICE_PROVIDER=yahoo_unofficial
# YAHOO_CHART_BASE_URL=https://query1.finance.yahoo.com/v8/finance/chart
# YAHOO_USER_AGENT=Mozilla/5.0
# PRICE_CACHE_TTL_SECONDS=43200
# PRICE_HISTORY_DAYS=400
#
# Commercial rollback option
# PRICE_PROVIDER=marketstack
# MARKETSTACK_ACCESS_KEY=your-marketstack-access-key
# MARKETSTACK_BASE_URL=https://api.marketstack.com/v2
# MARKETSTACK_JP_MIC=XTKS

# CORS (comma-separated)
# CORS_ALLOW_ORIGINS=https://investment-log-frontend.vercel.app,http://localhost:5173

# Rate limit
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=120
